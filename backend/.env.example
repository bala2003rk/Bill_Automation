PORT=5000
MONGODB_URI=mongodb://localhost:27017/billtrack
JWT_SECRET=billtrack_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Email — Gmail SMTP (use an App Password, NOT your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16char_app_password
FROM_EMAIL=BillTrack <noreply@billtrack.app>

# Cloudinary (sign up free at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173
